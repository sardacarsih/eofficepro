# Salin ke backend/.env untuk development lokal.
# Nilai default cocok dengan docker-compose.yml — JANGAN dipakai di production.

APP_ENV=development
HTTP_PORT=8080

# Port 5433: container Postgres di-map ke 5433 karena 5432 dipakai PostgreSQL lokal
DATABASE_URL=postgres://eoffice:eoffice_dev_secret@localhost:5433/eoffice?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=eoffice
MINIO_SECRET_KEY=eoffice_dev_secret
MINIO_BUCKET=eoffice-attachments
MINIO_USE_SSL=false

# Ganti dengan random 32+ karakter sebelum deploy
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_HOURS=168

# URL web app — dipakai untuk tautan reset password di email
WEB_BASE_URL=http://localhost:3000

# SMTP kosong = mode dev: email dicetak ke log API, tidak benar-benar terkirim
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=eoffice@ksk.local
