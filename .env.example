# Salin ke backend/.env untuk development lokal.
# Nilai default cocok dengan docker-compose.yml — JANGAN dipakai di production.

APP_ENV=development
HTTP_PORT=8080

# Port 5433: container Postgres di-map ke 5433 karena 5432 dipakai PostgreSQL lokal
DATABASE_URL=postgres://eoffice:eoffice_dev_secret@localhost:5433/eoffice?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=eoffice
MINIO_SECRET_KEY=eoffice_dev_secret
MINIO_BUCKET=eoffice-attachments
MINIO_USE_SSL=false

# ClamAV wajib untuk memindai lampiran karantina sebelum dapat diunduh/diajukan.
CLAMAV_ADDRESS=localhost:3310

# Ganti dengan random 32+ karakter sebelum deploy
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=30
# Sesi standar (login tanpa "ingat saya")
JWT_REFRESH_TTL_HOURS=24
# Sesi panjang saat "ingat saya" dicentang (30 hari)
JWT_REFRESH_REMEMBER_TTL_HOURS=720

# URL web app — dipakai untuk tautan di email dan URL verifikasi surat (QR).
# Dev dengan emulator Android: pakai http://10.0.2.2:3000 agar tombol
# Verifikasi di mobile bisa membuka halaman web verify dari emulator.
WEB_BASE_URL=http://localhost:3000

# SMTP kosong = mode dev: email dicetak ke log API, tidak benar-benar terkirim
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=eoffice@ksk.local

# Firebase Cloud Messaging untuk dev emulator.
FIREBASE_CLOUD_MESSAGING_ENABLED=true
FIREBASE_PROJECT_ID=eoffice-e6656
# Isi salah satu: path file service account atau JSON service account utuh dari secret manager.
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=
